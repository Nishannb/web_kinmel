# Kinmel web — environment variables
#
# Local development: create `.env.local` (gitignored) from the examples below.
# Production: set variables in Vercel → Project → Settings → Environment Variables.
# Do not commit `.env.local` or `.env.production`.

# Storefront URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.kinmel.shop

# Flask API — production
NEXT_PUBLIC_BACKEND_URL=https://api.kinmel.shop

# WebSockets (live overlay / comments) — must reach Flask directly
NEXT_PUBLIC_BACKEND_WS_URL=wss://api.kinmel.shop

# Server-side proxy for /kinmel-backend/* (Next route.ts)
KINMEL_BACKEND_PROXY_TARGET=https://api.kinmel.shop

# Optional: Open Graph facebook:appId when links are shared (public ID, not a secret).
# Code already has a fallback in lib/siteMetadata.ts if unset.
# NEXT_PUBLIC_FACEBOOK_APP_ID=695678696913661

# --- Local development (.env.local) example ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_BACKEND_URL=https://toothy-superconfused-maybell.ngrok-free.dev
# NEXT_PUBLIC_BACKEND_WS_URL=wss://toothy-superconfused-maybell.ngrok-free.dev
# KINMEL_BACKEND_PROXY_TARGET=https://toothy-superconfused-maybell.ngrok-free.dev

# Optional Supabase overrides (defaults in lib/publicConfig.ts)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional dev RTMP fallback
# NEXT_PUBLIC_INSTAGRAM_RTMP_URL=rtmps://...
